# ─── Database ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fleetos
DB_USER=fleetos
DB_PASS=change_me_in_production
DB_SSL=false

# ─── JWT ─────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_MINIMUM_256BIT_BASE64_ENCODED_SECRET
JWT_EXPIRY=24

# ─── OTP ─────────────────────────────────────────────
OTP_EXPIRY=10

# ─── Mail ────────────────────────────────────────────
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USER=apikey
MAIL_PASS=your_sendgrid_api_key
MAIL_FROM=noreply@fleetos.io

# ─── App ─────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000
SERVER_PORT=8080
SPRING_PROFILE=dev

# ─── QR codes ────────────────────────────────────────
QR_OUTPUT_DIR=/app/static/qr

# ─── CORS ────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── Logging ─────────────────────────────────────────
LOG_LEVEL=INFO
